# Copy to .env and fill in. The .env file is git-ignored.
# The same binary targets OpenAI, OpenRouter, or any OpenAI-compatible gateway.

# --- Provider selection ---
# "openai" (default) or "openrouter"
AGENT_PROVIDER=openai

# Override the endpoint for any OpenAI-compatible gateway (self-hosted, Azure,
# Groq, Together, local llama.cpp, etc.). Leave blank to use the provider default.
# AGENT_BASE_URL=https://api.openai.com/v1

# --- Authentication ---
# Generic key (preferred). If unset, the provider-specific key below is used.
# AGENT_API_KEY=

# Provider-conventional fallbacks:
OPENAI_API_KEY=sk-...
# OPENROUTER_API_KEY=sk-or-...

# --- Model & behaviour ---
# Default model. If unset: "gpt-4o-mini" (openai) or "openai/gpt-4o-mini" (openrouter).
# AGENT_MODEL=gpt-4o-mini
# AGENT_TEMPERATURE=0.7
# AGENT_MAX_STEPS=10
# AGENT_SYSTEM_PROMPT=You are a helpful assistant.

# --- Knowledge base (RAG) ---
# Directory of Markdown/text files the agent loads at startup and searches via
# the knowledge_search tool. Defaults to "knowledge". If it is missing or empty,
# the tool is simply not registered.
# AGENT_KNOWLEDGE_DIR=knowledge

# --- OpenRouter-only optional ranking headers ---
# OPENROUTER_REFERER=https://your-app.example
# OPENROUTER_TITLE=My Agent App
